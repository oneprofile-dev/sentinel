{
  "name": "@curatedmcp/sentinel",
  "version": "0.2.0",
  "description": "CuratedMCP's local-first action firewall for MCP servers",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sentinel": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./proxy": "./dist/proxy.js",
    "./policy": "./dist/policy.js",
    "./logger": "./dist/logger.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.spec.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "mcp-firewall",
    "mcp-proxy",
    "security",
    "firewall",
    "policy",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "cursor",
    "windsurf",
    "ai-agent",
    "curatedmcp"
  ],
  "author": "CuratedMCP",
  "homepage": "https://curatedmcp.com/sentinel",
  "repository": {
    "type": "git",
    "url": "https://github.com/curatedmcp/sentinel"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^11.0.0",
    "express": "^4.18.0",
    "minimatch": "^9.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
